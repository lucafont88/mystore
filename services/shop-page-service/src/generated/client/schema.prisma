generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("SHOP_PAGE_DATABASE_URL")
}

enum PageStatus {
  NEW_PAGE
  DRAFT
  PUBLISHED
}

model ShopPage {
  id          String            @id @default(uuid())
  title       String
  slug        String            @unique
  description String?
  status      PageStatus        @default(NEW_PAGE)
  vendorId    String
  htmlKey     String?
  builder     Json?
  publishedAt DateTime?
  products    ShopPageProduct[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("shop_pages")
}

model ShopPageProduct {
  id         String   @id @default(uuid())
  shopPageId String
  productId  String
  sortOrder  Int      @default(0)
  shopPage   ShopPage @relation(fields: [shopPageId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([shopPageId, productId])
  @@map("shop_page_products")
}
