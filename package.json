{
  "name": "mystore",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"pnpm --filter api-gateway dev\" \"pnpm --filter auth-service dev\"",
    "auth:migrate": "dotenv -e .env -- pnpm --filter auth-service exec prisma migrate dev",
    "product:migrate": "dotenv -e .env -- pnpm --filter product-service exec prisma migrate dev",
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",
    "infra:logs": "docker-compose logs -f",
    "monitoring:up": "docker compose -f docker-compose.yml -f docker-compose.monitoring.yml up -d",
    "monitoring:down": "docker compose -f docker-compose.yml -f docker-compose.monitoring.yml down",
    "monitoring:logs": "docker compose -f docker-compose.yml -f docker-compose.monitoring.yml logs -f",
    "monitoring:restart": "pnpm monitoring:down && pnpm monitoring:up",
    "dev:full": "pnpm monitoring:up && sleep 15 && pnpm dev",
    "traffic:gen": "node scripts/generate-traffic.js",
    "build:shared": "pnpm --filter @ecommerce/shared build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "axios": "^1.13.5",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
